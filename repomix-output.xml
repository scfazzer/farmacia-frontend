      <svg viewBox="0 0 20 20" fill="currentColor" width="15"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/></svg>
      Actualizar
    </button>
  </div>

  @if (error()) {
    <div class="alert alert-danger fade-in" style="margin-bottom:20px">{{ error() }}</div>
  }

  @if (loading()) {
    <div style="display:flex;justify-content:center;padding:80px"><div class="spinner"></div></div>
  } @else if (data()) {

    <!-- KPI Cards -->
    <div class="kpi-grid fade-in-2">
      <a class="kpi-card kpi-green" routerLink="/ventas">
        <div class="kpi-icon">
          <svg viewBox="0 0 20 20" fill="currentColor" width="22"><path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"/></svg>
        </div>
        <div class="kpi-content">
          <div class="kpi-label">Ventas hoy</div>
          <div class="kpi-value">{{ data()!.ventasHoy }}</div>
          <div class="kpi-sub">S/. {{ data()!.totalVentasHoy | number:'1.2-2' }}</div>
        </div>
      </a>

      <a class="kpi-card kpi-blue" routerLink="/ventas">
        <div class="kpi-icon">
          <svg viewBox="0 0 20 20" fill="currentColor" width="22"><path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm2 10a1 1 0 10-2 0v3a1 1 0 102 0v-3zm2-3a1 1 0 011 1v5a1 1 0 11-2 0v-5a1 1 0 011-1zm4-1a1 1 0 10-2 0v7a1 1 0 102 0V8z" clip-rule="evenodd"/></svg>
        </div>
        <div class="kpi-content">
          <div class="kpi-label">Ventas del mes</div>
          <div class="kpi-value">{{ data()!.ventasMes }}</div>
          <div class="kpi-sub">S/. {{ data()!.totalVentasMes | number:'1.2-2' }}</div>
        </div>
      </a>

      <a class="kpi-card kpi-purple" routerLink="/medicamentos">
        <div class="kpi-icon">
          <svg viewBox="0 0 20 20" fill="currentColor" width="22"><path fill-rule="evenodd" d="M11.47 2.47a.75.75 0 011.06 0l5 5a.75.75 0 010 1.06l-10 10a.75.75 0 01-1.06 0l-5-5a.75.75 0 010-1.06l10-10zm.97 8.5l-1.5-1.5L7 13.44l1.5 1.5 3.94-3.97zM5.47 8.53l3.5 3.5L10.44 10.5 6.94 7 5.47 8.53z" clip-rule="evenodd"/></svg>
        </div>
        <div class="kpi-content">
          <div class="kpi-label">Medicamentos</div>
          <div class="kpi-value">{{ data()!.totalMedicamentos }}</div>
          <div class="kpi-sub">en inventario</div>
        </div>
      </a>

      <a class="kpi-card kpi-orange" routerLink="/clientes">
        <div class="kpi-icon">
          <svg viewBox="0 0 20 20" fill="currentColor" width="22"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/></svg>
        </div>
        <div class="kpi-content">
          <div class="kpi-label">Clientes</div>
          <div class="kpi-value">{{ data()!.totalClientes }}</div>
          <div class="kpi-sub">registrados</div>
        </div>
      </a>
    </div>

    <!-- Alertas row -->
    @if (data()!.medicamentosStockBajo > 0 || data()!.medicamentosProximosAVencer > 0) {
      <div class="alerts-row fade-in-3">
        @if (data()!.medicamentosStockBajo > 0) {
          <a class="alert-banner alert-danger" routerLink="/medicamentos">
            <svg viewBox="0 0 20 20" fill="currentColor" width="18"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
            <strong>{{ data()!.medicamentosStockBajo }}</strong> medicamento(s) con stock bajo
            <svg viewBox="0 0 20 20" fill="currentColor" width="14" style="margin-left:auto"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
          </a>
        }
        @if (data()!.medicamentosProximosAVencer > 0) {
          <a class="alert-banner alert-warning" routerLink="/medicamentos">
            <svg viewBox="0 0 20 20" fill="currentColor" width="18"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
            <strong>{{ data()!.medicamentosProximosAVencer }}</strong> medicamento(s) próximos a vencer (60d)
            <svg viewBox="0 0 20 20" fill="currentColor" width="14" style="margin-left:auto"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
          </a>
        }
      </div>
    }

    <!-- Tables row -->
    <div class="tables-row fade-in-4">
      <!-- Stock bajo -->
      <div class="card">
        <div class="card-header">
          <h3>⚠️ Stock Bajo</h3>
          <a routerLink="/medicamentos" class="btn btn-ghost btn-sm">Ver todos</a>
        </div>
        @if (stockBajo().length === 0) {
          <div class="empty-state" style="padding:32px">
            <p class="text-muted" style="font-size:.875rem">✅ Todos los medicamentos tienen stock suficiente</p>
          </div>
        } @else {
          <div class="table-wrapper">
            <table class="table">
              <thead><tr><th>Medicamento</th><th>Stock</th></tr></thead>
              <tbody>
                @for (m of stockBajo(); track m.id) {
                  <tr>
                    <td>
                      <div style="font-weight:600;font-size:.85rem">{{ m.nombre }}</div>
                      <div style="font-size:.72rem;color:var(--gray-500)">{{ m.categoriaNombre }}</div>
                    </td>
                    <td>
                      <div class="stock-bar-wrap">
                        <div class="stock-bar"><div class="stock-bar-fill {{ stockClass(m) }}" [style.width]="stockPct(m)+'%'"></div></div>
                        <span style="font-size:.82rem;font-weight:700;color:var(--danger)">{{ m.stock }}</span>
                      </div>
                      <div style="font-size:.7rem;color:var(--gray-500)">Mín: {{ m.stockMinimo }}</div>
                    </td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        }
      </div>

      <!-- Por vencer -->
      <div class="card">
        <div class="card-header">
          <h3>📅 Próximos a Vencer</h3>
          <a routerLink="/medicamentos" class="btn btn-ghost btn-sm">Ver todos</a>
        </div>
        @if (porVencer().length === 0) {
          <div class="empty-state" style="padding:32px">
            <p class="text-muted" style="font-size:.875rem">✅ Ningún medicamento vence en los próximos 60 días</p>
          </div>
        } @else {
          <div class="table-wrapper">
            <table class="table">
              <thead><tr><th>Medicamento</th><th>Vence</th></tr></thead>
              <tbody>
                @for (m of porVencer(); track m.id) {
                  <tr>
                    <td>
                      <div style="font-weight:600;font-size:.85rem">{{ m.nombre }}</div>
                      <div style="font-size:.72rem;color:var(--gray-500)">{{ m.categoriaNombre }}</div>
                    </td>
                    <td>
                      <div style="font-size:.82rem">{{ m.fechaVencimiento | date:'dd/MM/yyyy' }}</div>
                      <span [class]="'badge ' + urgenciaBadge(diasParaVencer(m.fechaVencimiento))" style="font-size:.65rem;margin-top:2px">{{ diasParaVencer(m.fechaVencimiento) }}d</span>
                    </td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        }
      </div>
    </div>
  }
</div>

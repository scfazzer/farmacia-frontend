.kpi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 14px;
  margin-bottom: 16px;
}

.kpi-card {
  display: flex; align-items: center; gap: 16px;
  padding: 20px;
  background: var(--white);
  border-radius: var(--radius-lg);
  border: 1.5px solid var(--gray-200);
  box-shadow: var(--shadow-sm);
  text-decoration: none;
  color: inherit;
  transition: var(--transition);
  position: relative; overflow: hidden;
}
.kpi-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0;
  height: 3px; border-radius: 2px 2px 0 0;
}
.kpi-card:hover { transform: translateY(-2px); box-shadow: var(--shadow); }

.kpi-green::before  { background: var(--accent); }
.kpi-blue::before   { background: var(--info); }
.kpi-purple::before { background: #8b5cf6; }
.kpi-orange::before { background: var(--warning); }

.kpi-icon {
  width: 46px; height: 46px; border-radius: var(--radius);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.kpi-green  .kpi-icon { background: var(--accent-light); color: var(--accent); }
.kpi-blue   .kpi-icon { background: var(--info-light);   color: var(--info); }
.kpi-purple .kpi-icon { background: #ede9fe; color: #7c3aed; }
.kpi-orange .kpi-icon { background: var(--warning-light); color: #d97706; }

.kpi-label { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--gray-500); margin-bottom: 2px; }
.kpi-value { font-family: 'Sora', sans-serif; font-size: 2rem; font-weight: 800; color: var(--gray-900); line-height: 1.1; }
.kpi-sub   { font-size: .78rem; color: var(--gray-500); margin-top: 2px; }

.alerts-row {
  display: flex; flex-direction: column; gap: 8px;
  margin-bottom: 16px;
}
.alert-banner {
  display: flex; align-items: center; gap: 10px;
  padding: 12px 16px; border-radius: var(--radius);
  font-size: .875rem; font-weight: 500;
  text-decoration: none;
  transition: var(--transition);
}
.alert-banner:hover { filter: brightness(.97); }
.alert-banner.alert-danger  { background: var(--danger-light); color: #dc2626; border: 1px solid #fecaca; }
.alert-banner.alert-warning { background: var(--warning-light); color: #b45309; border: 1px solid #fde68a; }

.tables-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

@media (max-width: 768px) {
  .kpi-grid    { grid-template-columns: 1fr 1fr; }
  .tables-row  { grid-template-columns: 1fr; }
  .kpi-value   { font-size: 1.6rem; }
}
@media (max-width: 480px) {
  .kpi-grid { grid-template-columns: 1fr; }
}

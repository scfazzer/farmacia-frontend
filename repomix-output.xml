          </div>
        </div>
        <table class="table" style="margin-bottom:16px">
          <thead><tr><th>Medicamento</th><th>Cant.</th><th>Precio Unit.</th><th>Subtotal</th></tr></thead>
          <tbody>
            @for (d of ventaDetalle()!.detalles; track d.id) {
              <tr>
                <td>{{ d.medicamentoNombre }}</td>
                <td>{{ d.cantidad }}</td>
                <td>S/. {{ d.precioUnitario | number:'1.2-2' }}</td>
                <td style="font-weight:600">S/. {{ d.subtotal | number:'1.2-2' }}</td>
              </tr>
            }
          </tbody>
        </table>
        <div style="text-align:right;font-family:'Sora',sans-serif;font-size:1.3rem;font-weight:800;color:var(--accent)">
          Total: S/. {{ ventaDetalle()!.totalVenta | number:'1.2-2' }}
        </div>
        @if (ventaDetalle()!.observacion) {

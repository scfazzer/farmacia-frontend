          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32"><path stroke-linecap="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        </div>
        <p class="empty-title">Sin resultados</p>
        <p class="empty-desc">No se encontraron medicamentos.</p>
      </div>
    } @else {
      <div class="table-wrapper">
        <table class="table">
          <thead>
            <tr>
              <th>Medicamento</th>
              <th>Categoría</th>
              <th>Stock</th>
              <th>Precio</th>
              <th>Vencimiento</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            @for (m of items(); track m.id) {
              <tr>
                <td>
                  <div style="font-weight:600;color:var(--gray-900)">{{ m.nombre }}</div>
                  <div style="font-size:.78rem;color:var(--gray-500)">{{ m.principioActivo }} · {{ m.presentacion }}</div>
                  @if (m.requiereReceta) {
                    <span class="badge badge-warning" style="margin-top:3px;font-size:.65rem">🩺 Receta</span>
                  }
                </td>
                <td><span class="badge badge-info">{{ m.categoriaNombre }}</span></td>
                <td style="min-width:130px">
                  <div class="stock-bar-wrap">
                    <div class="stock-bar">
                      <div class="stock-bar-fill {{ stockClass(m) }}" [style.width]="stockPct(m) + '%'"></div>
                    </div>
                    <span style="font-size:.82rem;font-weight:600;min-width:28px;text-align:right"
                          [class.text-danger]="m.stockBajo">{{ m.stock }}</span>
                  </div>
                  @if (m.stockBajo) {
                    <div style="font-size:.7rem;color:var(--danger)">⚠ Stock bajo (mín {{ m.stockMinimo }})</div>
                  }
                </td>
                <td>
                  <div style="font-weight:700;color:var(--accent)">S/. {{ m.precioVenta | number:'1.2-2' }}</div>
                  @if (m.precioCompra) {
                    <div style="font-size:.75rem;color:var(--gray-500)">Compra: S/. {{ m.precioCompra | number:'1.2-2' }}</div>
                  }
                </td>
                <td>
                  @if (m.fechaVencimiento) {
                    <div [class.text-danger]="diasVencer(m.fechaVencimiento) <= 30" [class.text-warning]="diasVencer(m.fechaVencimiento) > 30 && diasVencer(m.fechaVencimiento) <= 90">
                      {{ m.fechaVencimiento | date:'dd/MM/yyyy' }}
                    </div>
                    @if (diasVencer(m.fechaVencimiento) <= 90) {
                      <div style="font-size:.72rem" [class.text-danger]="diasVencer(m.fechaVencimiento) <= 30">{{ diasVencer(m.fechaVencimiento) }}d restantes</div>
                    }
                  } @else {
                    <span class="text-muted">—</span>
                  }
                </td>
                <td>
                  <span class="badge" [class.badge-success]="m.activo" [class.badge-gray]="!m.activo">
                    {{ m.activo ? 'Activo' : 'Inactivo' }}
                  </span>
                </td>
                <td>
                  <div style="display:flex;gap:6px">
                    <button class="btn btn-ghost btn-icon btn-sm" title="Editar" (click)="openEdit(m)">
                      <svg viewBox="0 0 20 20" fill="currentColor" width="15"><path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/></svg>
                    </button>
                    <button class="btn btn-ghost btn-icon btn-sm" title="Desactivar" (click)="confirmDelete(m.id)" style="color:var(--danger)">
                      <svg viewBox="0 0 20 20" fill="currentColor" width="15"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    </button>
                  </div>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>

      @if (totalPag() > 1) {
        <div class="pagination">
          <span class="pagination-info">
            Página {{ pagina() + 1 }} de {{ totalPag() }} · {{ total() }} registros
          </span>
          <div class="pagination-btns">
            <button class="page-btn" (click)="ir(pagina() - 1)" [disabled]="pagina() === 0">‹</button>
            @for (p of pages(); track p) {
              <button class="page-btn" [class.active]="p === pagina()" (click)="ir(p)">{{ p + 1 }}</button>
            }
            <button class="page-btn" (click)="ir(pagina() + 1)" [disabled]="pagina() >= totalPag() - 1">›</button>
          </div>
        </div>
      }
    }
  </div>
</div>

<!-- Modal Crear/Editar -->
@if (showModal()) {

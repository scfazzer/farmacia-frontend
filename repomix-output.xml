/* ── Shell ── */
.app-shell {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* ── Navbar ── */
.navbar {
  position: sticky; top: 0; z-index: 100;
  background: var(--accent);
  box-shadow: 0 2px 12px rgba(22,163,74,.25);
}

.navbar-inner {
  display: flex; align-items: center;
  height: var(--navbar-h);
  padding: 0 24px;
  gap: 8px;
  max-width: 1600px; margin: 0 auto; width: 100%;
}

/* Brand */
.navbar-brand {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none; flex-shrink: 0;
}
.brand-icon {
  width: 34px; height: 34px;
  background: rgba(255,255,255,.2);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
}
.brand-icon svg { width: 18px; height: 18px; }
.brand-name {
  font-family: 'Sora', sans-serif;
  font-size: 1.1rem; font-weight: 800;
  color: white; letter-spacing: -.01em;
}

/* Nav links */
.navbar-nav {
  display: flex; align-items: center;
  margin-left: 24px; gap: 2px; flex: 1;
}
.nav-link {
  display: flex; align-items: center; gap: 7px;
  padding: 7px 13px; border-radius: 8px;
  font-size: 0.85rem; font-weight: 600;
  color: rgba(255,255,255,.75);
  text-decoration: none;
  transition: all .15s ease;
  white-space: nowrap;
}
.nav-link:hover {
  background: rgba(255,255,255,.15);
  color: white;
}
.nav-link.active {
  background: rgba(255,255,255,.22);
  color: white;
  box-shadow: 0 1px 4px rgba(0,0,0,.12);
}
.nav-link-icon { display: flex; align-items: center; flex-shrink: 0; }

/* End */
.navbar-end {
  display: flex; align-items: center; gap: 10px;
  margin-left: auto; flex-shrink: 0;
}

.user-pill {
  display: flex; align-items: center; gap: 10px;
  padding: 5px 12px 5px 6px;
  background: rgba(255,255,255,.15);
  border-radius: 40px;
}
.user-avatar {
  width: 30px; height: 30px; border-radius: 50%;
  background: rgba(255,255,255,.3);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Sora', sans-serif;
  font-size: 0.85rem; font-weight: 700; color: white;
  flex-shrink: 0;
}
.user-info { display: flex; flex-direction: column; gap: 1px; }
.user-name { font-size: 0.8rem; font-weight: 600; color: white; line-height: 1.2; max-width: 130px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.user-info .badge { font-size: 0.65rem; padding: 1px 7px; }
.user-info .badge-success { background: rgba(255,255,255,.25); color: white; }
.user-info .badge-gray    { background: rgba(0,0,0,.2); color: rgba(255,255,255,.8); }

.btn-logout {
  width: 34px; height: 34px; border-radius: 8px;
  background: rgba(255,255,255,.15);

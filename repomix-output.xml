<div class="page fade-in">
  <div class="page-header">
    <div>
      <h1 class="page-title">🛒 Ventas</h1>
      <p class="page-subtitle">Registro y seguimiento de ventas</p>
    </div>
    <button class="btn btn-primary" (click)="openCreate()">
      <svg viewBox="0 0 20 20" fill="currentColor" width="16"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
      Nueva Venta
    </button>
  </div>

  <!-- Stats rápidas -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin-bottom:20px">
    <div class="card card-body fade-in-2" style="padding:18px">
      <div style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--gray-500);margin-bottom:4px">Ventas hoy</div>
      <div style="font-family:'Sora',sans-serif;font-size:1.8rem;font-weight:800;color:var(--gray-900)">{{ ventasHoy() }}</div>
    </div>
    <div class="card card-body fade-in-3" style="padding:18px">
      <div style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--gray-500);margin-bottom:4px">Total hoy</div>
      <div style="font-family:'Sora',sans-serif;font-size:1.8rem;font-weight:800;color:var(--accent)">S/. {{ totalHoy() | number:'1.2-2' }}</div>
    </div>
    <div class="card card-body fade-in-4" style="padding:18px">
      <div style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--gray-500);margin-bottom:4px">Total ventas</div>
      <div style="font-family:'Sora',sans-serif;font-size:1.8rem;font-weight:800;color:var(--gray-900)">{{ items().length }}</div>
    </div>
  </div>

  @if (success()) { <div class="alert alert-success fade-in" style="margin-bottom:16px">✓ {{ success() }}</div> }

  <div class="card fade-in-2">
    <div class="toolbar">
      <div class="toolbar-left">
        <div class="search-bar">
          <svg viewBox="0 0 20 20" fill="currentColor" width="16"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/></svg>
          <input class="search-input" type="text" placeholder="Buscar por cliente o N°..." (input)="onSearch($event)">
        </div>
        <select class="filter-select" (change)="onFilterEstado($event)">
          <option value="">Todos los estados</option>
          <option value="COMPLETADA">Completadas</option>
          <option value="ANULADA">Anuladas</option>
        </select>
      </div>
    </div>

    @if (loading()) {
      <div style="display:flex;justify-content:center;padding:60px"><div class="spinner"></div></div>
    } @else {
      <div class="table-wrapper">
        <table class="table">
          <thead>
            <tr>
              <th>N° Venta</th>
              <th>Fecha</th>
              <th>Cliente</th>
              <th>Productos</th>
              <th>Total</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            @for (v of filtered(); track v.id) {
              <tr>
                <td><span style="font-family:monospace;font-weight:700;color:var(--accent)">#{{ v.id.toString().padStart(4,'0') }}</span></td>
                <td style="font-size:.82rem">{{ v.fechaVenta | date:'dd/MM/yyyy HH:mm' }}</td>
                <td>
                  @if (v.clienteNombre) {
                    <div style="font-weight:600">{{ v.clienteNombre }}</div>
                    <div style="font-size:.75rem;color:var(--gray-500)">DNI: {{ v.clienteDni }}</div>
                  } @else {
                    <span class="badge badge-gray">Cliente ocasional</span>
                  }
                </td>
                <td><span class="badge badge-info">{{ v.detalles ? v.detalles.length : 0 }} ítem(s)</span></td>
                <td style="font-family:'Sora',sans-serif;font-weight:700;font-size:1rem;color:var(--gray-900)">
                  S/. {{ v.totalVenta | number:'1.2-2' }}
                </td>
                <td>
                  <span class="badge" [class.badge-success]="v.estado==='COMPLETADA'" [class.badge-danger]="v.estado==='ANULADA'">
                    {{ v.estado }}
                  </span>
                </td>
                <td>
                  <div style="display:flex;gap:6px">
                    <button class="btn btn-ghost btn-icon btn-sm" title="Ver detalle" (click)="verDetalle(v)">
                      <svg viewBox="0 0 20 20" fill="currentColor" width="15"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg>
                    </button>
                    @if (v.estado === 'COMPLETADA') {
                      <button class="btn btn-ghost btn-icon btn-sm" title="Anular" (click)="anular(v.id)" style="color:var(--danger)">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="15"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                      </button>
                    }
                  </div>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>
</div>

<!-- Modal Nueva Venta -->
@if (showModal()) {
  <div class="modal-overlay" (click)="closeModal()">
    <div class="modal modal-xl" (click)="$event.stopPropagation()" style="max-height:92vh">
      <div class="modal-header">
        <h2>🛒 Nueva Venta</h2>
        <button class="btn btn-ghost btn-icon" (click)="closeModal()">
          <svg viewBox="0 0 20 20" fill="currentColor" width="18"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
        </button>
      </div>
      <div class="modal-body">
        @if (error()) { <div class="alert alert-danger" style="margin-bottom:14px">{{ error() }}</div> }
        <form [formGroup]="form">
          <div class="form-grid" style="margin-bottom:20px">
            <div class="form-group">
              <label class="form-label">Cliente (opcional)</label>
              <select class="form-control filter-select" formControlName="clienteId" style="padding:10px 14px">
                <option [value]="null">Cliente ocasional (sin registro)</option>
                @for (c of clientes(); track c.id) {
                  <option [value]="c.id">{{ c.nombre }} — {{ c.dni }}</option>
                }
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Observación</label>
              <input class="form-control" formControlName="observacion" placeholder="Notas opcionales...">
            </div>
          </div>

          <div style="margin-bottom:12px">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
              <h4 style="font-size:.9rem;font-weight:700">Productos</h4>
              <button type="button" class="btn btn-secondary btn-sm" (click)="agregarDetalle()">+ Agregar producto</button>
            </div>

            @for (ctrl of detallesArray.controls; track ctrl; let i = $index) {
              <div [formGroup]="$any(ctrl)" style="display:grid;grid-template-columns:1fr 100px auto;gap:10px;align-items:end;margin-bottom:10px;padding:12px;background:var(--gray-50);border-radius:var(--radius)">
                <div class="form-group" style="margin:0">
                  <label class="form-label">Medicamento *</label>
                  <select class="form-control filter-select" formControlName="medicamentoId" style="padding:9px 14px">
                    <option value="">Seleccionar...</option>
                    @for (m of medicamentos(); track m.id) {
                      <option [value]="m.id">{{ m.nombre }} · S/. {{ m.precioVenta.toFixed(2) }} (stock: {{ m.stock }})</option>
                    }
                  </select>
                </div>
                <div class="form-group" style="margin:0">
                  <label class="form-label">Cantidad</label>
                  <input class="form-control" type="number" min="1" formControlName="cantidad">
                </div>
                <button type="button" class="btn btn-ghost btn-icon" (click)="quitarDetalle(i)" style="color:var(--danger);margin-bottom:0">
                  <svg viewBox="0 0 20 20" fill="currentColor" width="16"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                </button>
              </div>
            }
          </div>

          <div style="background:var(--accent-muted);border:1.5px solid var(--accent-light);border-radius:var(--radius);padding:14px 18px;display:flex;justify-content:space-between;align-items:center">
            <span style="font-weight:600;color:var(--accent-dark)">Total estimado:</span>
            <span style="font-family:'Sora',sans-serif;font-size:1.4rem;font-weight:800;color:var(--accent)">
              S/. {{ totalCalculado() | number:'1.2-2' }}
            </span>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" (click)="closeModal()">Cancelar</button>
        <button class="btn btn-primary" (click)="save()" [disabled]="form.invalid || saving()">
          @if (saving()) { <div class="spinner spinner-sm"></div> }
          Registrar Venta
        </button>
      </div>
    </div>
  </div>
}

<!-- Modal Detalle Venta -->
@if (showDetalle() && ventaDetalle()) {
  <div class="modal-overlay" (click)="showDetalle.set(false)">
    <div class="modal modal-lg" (click)="$event.stopPropagation()">
      <div class="modal-header">

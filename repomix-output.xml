.mobile-logout:hover { background: rgba(255,255,255,.1); color: white; }

/* ── Main content ── */
.main-content {
  flex: 1;
  overflow-y: auto;
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .navbar-nav, .user-pill, .btn-logout { display: none; }
  .mobile-burger { display: flex; }
  .navbar-inner { justify-content: space-between; }
}
@media (min-width: 901px) {
  .mobile-nav { display: none; }
}
